<% layout("/layouts/boilerplate") %>

  <div class="row mt-4 mb-5">
    <div class="col-12 col-md-6 offset-md-3">

      <div
        style="background:var(--bs-white,#fff); border:1px solid #eee; border-radius:16px; padding:2rem; box-shadow:0 2px 16px rgba(0,0,0,0.07);">

        <div style="display:flex; align-items:center; gap:12px; margin-bottom:1.5rem;">
          <div
            style="width:42px; height:42px; border-radius:50%; background:#fe424d; display:flex; align-items:center; justify-content:center;">
            <i class="fa-solid fa-house-chimney" style="color:white; font-size:18px;"></i>
          </div>
          <div>
            <h4 style="margin:0; font-weight:600;">Create a New Listing</h4>
            <p style="margin:0; font-size:13px; color:#888;">Fill in the details to list your property</p>
          </div>
        </div>

        <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:14px;">
              <i class="fa-solid fa-heading" style="color:#fe424d; font-size:13px; margin-right:6px;"></i>Title
            </label>
            <input name="listing[title]" placeholder="e.g. Cozy Beach House in Goa" type="text" class="form-control"
              required style="border-radius:10px;" />
            <div class="invalid-feedback">Please enter a title.</div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:14px;">
              <i class="fa-solid fa-align-left" style="color:#fe424d; font-size:13px; margin-right:6px;"></i>Description
            </label>
            <textarea name="listing[description]"
              placeholder="Describe your property — amenities, vibe, nearby attractions..." class="form-control"
              rows="4" required style="border-radius:10px;"></textarea>
            <div class="invalid-feedback">Please write a short description.</div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:14px;">
              <i class="fa-solid fa-image" style="color:#fe424d; font-size:13px; margin-right:6px;"></i>Upload Image
            </label>
            <input type="file" name="image" class="form-control" accept="image/*" required
              style="border-radius:10px;" />
            <div class="form-text" style="font-size:12px;">Upload a high quality photo of your property</div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-5">
              <label class="form-label fw-semibold" style="font-size:14px;">
                <i class="fa-solid fa-indian-rupee-sign"
                  style="color:#fe424d; font-size:13px; margin-right:6px;"></i>Price / night
              </label>
              <div class="input-group">
                <span class="input-group-text"
                  style="border-radius:10px 0 0 10px; background:#f9f9f9; border-color:#dee2e6;">₹</span>
                <input name="listing[price]" placeholder="2000" type="number" class="form-control" required
                  style="border-radius:0 10px 10px 0;" />
              </div>
              <div class="invalid-feedback">Enter a valid price.</div>
            </div>

            <div class="col-7">
              <label class="form-label fw-semibold" style="font-size:14px;">
                <i class="fa-solid fa-flag" style="color:#fe424d; font-size:13px; margin-right:6px;"></i>Country
              </label>
              <input name="listing[country]" placeholder="India" type="text" class="form-control" required
                style="border-radius:10px;" />
              <div class="invalid-feedback">Enter country name.</div>
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold" style="font-size:14px;">
              <i class="fa-solid fa-location-dot" style="color:#fe424d; font-size:13px; margin-right:6px;"></i>Location
            </label>
            <input name="listing[location]" placeholder="e.g. Calangute, Goa" type="text" class="form-control" required
              style="border-radius:10px;" />
            <div class="form-text" style="font-size:12px;">This will be used to show your property on the map</div>
            <div class="invalid-feedback">Enter a valid location.</div>
          </div>

          <button class="btn w-100 text-white fw-semibold"
            style="background:#fe424d; border-radius:10px; padding:12px; font-size:15px; border:none;">
            <i class="fa-solid fa-plus me-2"></i>Add Listing
          </button>

        </form>
      </div>

    </div>
  </div>

  <script>
    (() => {
      const forms = document.querySelectorAll('.needs-validation');
      forms.forEach(form => {
        form.addEventListener('submit', e => {
          if (!form.checkValidity()) {
            e.preventDefault();
            e.stopPropagation();
          }
          form.classList.add('was-validated');
        });
      });
    })();
  </script>