<% layout("/layouts/boilerplate") %>

  <div class="hero-section">
    <div class="hero-content">
      <p class="hero-sub">Welcome To BookMyStay</p>
      <h1>Book Your Stay at <span style="color:#fe424d;">Dream</span> Location</h1>
      <form action="/listings" method="GET" class="hero-search-bar">
        <input type="text" name="search" placeholder="Where do you want to go?" class="hero-input"
          value="<%= search %>" />
        <div class="hero-divider"></div>
        <input type="date" name="checkIn" class="hero-input" />
        <div class="hero-divider"></div>
        <input type="number" name="guests" min="1" max="20" placeholder="Guests" class="hero-input"
          style="max-width:130px;" />
        <button type="submit" class="hero-btn">SEARCH →</button>
      </form>
    </div>
  </div>


  <style>
    #filters {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 0.5rem;
      margin-bottom: 20px;
    }

    #filters::-webkit-scrollbar {
      display: none;
    }

    .filter {
      min-width: 90px;
      padding: 12px;
      text-align: center;
      border-radius: 20px;
      background: #fff;

      box-shadow:
        0 4px 10px rgba(0, 0, 0, 0.1),
        0 8px 20px rgba(0, 0, 0, 0.08);

      transition: all 0.3s ease;
      margin: 9px;
    }

    .filter:hover {
      transform: translateY(-6px);
      box-shadow:
        0 10px 20px rgba(0, 0, 0, 0.15),
        0 15px 30px rgba(0, 0, 0, 0.12);
    }

    .filter p {
      font-size: 0.8rem;
    }

    .tax-info {
      display: none;
    }

    .tax-toggle {
      display: flex;
      align-items: center;

      padding: 0.8rem 1.2rem;

      background: white;

      border: 1px solid #ddd;
      border-radius: 16px;

      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);

      transition: all 0.3s ease;
    }

    .tax-toggle:hover {
      transform: translateY(-2px);

      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    }

    .listing-card {
      position: relative;
      border: none !important;
      background: transparent;
      margin-bottom: 1.5rem;
    }

    /* Yeh naya add karo */
    .card-img-wrapper {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
    }

    .card-img-top {
      height: 280px;
      width: 100%;
      object-fit: cover;
      display: block;
      /* gap hatata hai */
      border-radius: 20px;
    }

    .wishlist-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.9);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
    }

    .wishlist-btn i {
      font-size: 14px;
      color: #555;
    }

    .wishlist-btn:hover i {
      color: #fe424d;
    }

    .listing-rating {
      position: absolute;
      bottom: 12px;
      /* image ke andar bottom pe */
      left: 12px;
      background: rgba(0, 0, 0, 0.6);
      color: white;
      padding: 4px 10px;
      border-radius: 20px;
      font-size: 12px;
      z-index: 10;
    }

    .card-body {
      padding: 10px 4px !important;
    }

    .listing-title {
      font-size: 15px;
      font-weight: 600;
    }

    .listing-location {
      font-size: 13px;
      color: #666;
    }

    .listing-location i {
      color: #fe424d;
      font-size: 12px;
    }

    .card-price {
      font-size: 15px;
      font-weight: 700;
    }
  </style>
  <div id="filters">
    <div class="filter">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic cities</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </div>
    <div class="filter">
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing pools</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-igloo"></i></div>
      <p>Doms</p>
    </div>
    <div class="filter">
      <div><i class="fa-solid fa-sailboat"></i></div>
      <p>Boats</p>
    </div>

    <div class="tax-toggle">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">After Taxes</label>
      </div>
    </div>

  </div>

  <% if (search && search.trim() !=="" ) { %>
    <div class="col-12 mb-3">
      <p class="text-muted">
        <% if (allListings.length> 0) { %>
          <strong>
            <%= allListings.length %>
          </strong> result<%= allListings.length> 1 ? "s" : "" %> for "<%= search %>"
              <% } else { %>
                No listings found for "<%= search %>" 😕
                  <a href="/listings" class="ms-2 text-danger">Clear search</a>
                  <% } %>
      </p>
    </div>
    <% } %>

      <div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of allListings) { %>
          <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none text-dark">
            <div class="card listing-card">

              <!-- Image wrapper — yahi fix hai -->
              <div class="card-img-wrapper">
                <img src="<%= listing.image.url %>" class="card-img-top" />

                <!-- Heart button — top right -->
                <button class="wishlist-btn">
                  <i class="fa-regular fa-heart"></i>
                </button>

                <!-- Rating badge — bottom left, image ke andar -->
                <div class="listing-rating">
                  <% if(listing.totalReviews> 0) { %>
                    ⭐ <%= listing.avgRating %>
                      <% } else { %>
                        New
                        <% } %>
                </div>
              </div>

              <div class="card-body">
                <p class="listing-title mb-1">
                  <%= listing.title %>
                </p>
                <p class="listing-location mb-1">
                  <i class="fa-solid fa-location-dot"></i>
                  <%= listing.location.split(",")[0] %>
                </p>
                <p class="card-price">
                  ₹<%= listing.price.toLocaleString("en-IN") %>/night
                    <i class="tax-info"> +18% GST</i>
                </p>
              </div>
            </div>
          </a>
          <% } %>
      </div>

      <script>
        let taxSwitch = document.getElementById("switchCheckDefault");

        taxSwitch.addEventListener("change", () => {
          let taxinfo = document.getElementsByClassName("tax-info");
          for (info of taxinfo) {
            if (info.style.display != "inline") {
              info.style.display = "inline";
            } else {
              info.style.display = "none";
            }

          }
        });
      </script>