<% layout("/layouts/boilerplate") %>

  <div class="row mt-3">
    <div class="col-8 offset-2">
      <h3>Edit your listing</h3>

      <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation"
        enctype="multipart/form-data">
        <div class="mb-3">
          <label>Title</label>
          <input name="listing[title]" value="<%= listing.title %>" class="form-control" required />
          <div class="valid-feedback">Title looks good!</div>
        </div>

        <div class="mb-3">
          <label>Description</label>
          <textarea name="listing[description]" class="form-control" required>
        <%= listing.description %></textarea>
          <div class="valid-feedback">Write a Description!</div>
        </div>

        <div class="mb-3">
          <label>upload New Image </label>
          <input name="listing[image]" type="file" class="form-control" />
          <div class="valid-feedback">Enter a valid image link!</div>
        </div>

        <div class="row">
          <div class="mb-3 col-md-4">
            <label>Price</label>
            <input name="listing[price]" value="<%= listing.price %>" type="number" class="form-control" required />
            <div class="valid-feedback">Price should be valid!</div>
          </div>

          <div class="mb-3 col-md-8">
            <label>Country</label>
            <input name="listing[country]" value="<%= listing.country %>" class="form-control" required />
            <div class="valid-feedback">Country name should be valid!</div>
          </div>
        </div>

        <div class="mb-3">
          <label>Location</label>
          <input name="listing[location]" value="<%= listing.location %>" class="form-control" required />
          <div class="valid-feedback">Location should be valid!</div>
        </div>
        <button class="btn edit-btn mt-3">Edit</button>
      </form>
    </div>
  </div>