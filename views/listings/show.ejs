<% layout("/layouts/boilerplate") %>

<!-- ✅ Mapbox CDN (IMPORTANT - top pe hona chahiye) -->
<script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
<link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />

<!-- ✅ Backend data frontend me bhejna -->
<script>
  const mapToken = "<%= process.env.MAPBOX_TOKEN %>";
  const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
</script>

<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>

  <div class="card col-6 offset-3 show-card listing-card">
   <img src="/<%= listing.image.url %>" /> class="card-img-top show-img" />

    <div class="card-body">
      <p>Owned by <%= listing.owner ? listing.owner.username : "Admin" %></p>
      <p><%= listing.description %></p>
      <p>₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></p>
      <p><%= listing.location %></p>
      <p><%= listing.country %></p>
    </div>
  </div>

  <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
    <div class="btns">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button class="btn btn-danger offset-4">Delete</button>
      </form>
    </div>
  <% } %>

  <div class="col-8 offset-3 mb-3">
    <hr />

    <% if(currUser) { %>
      <h4>Leave a Review</h4>

      <form action="/listings/<%= listing._id %>/reviews" method="POST">
        <textarea name="review[comment]" class="form-control" required></textarea>
        <button class="btn btn-outline-dark mt-2">Submit</button>
      </form>
      <hr />
    <% } %>

    <% if(listing.reviews.length > 0) { %>
      <div class="row">
        <% for (let review of listing.reviews) { %>
          <div class="card col-5 ms-3 mb-3">
            <div class="card-body">
              <h5><%= review.author ? review.author.username : "Anonymous" %></h5>
              <p><%= review.comment %></p>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <!-- ✅ MAP SECTION -->
  <div class="col-8 offset-3 mb-3">
    <h3>Where you'll be</h3>
    <div id="map"></div>
  </div>
</div>

<!-- ✅ Map JS LAST me -->
<script src="/js/map.js"></script>