<% layout("/layouts/boilerplate") %>


  <div class="row mt-3">

    <div class="col-8 offset-2">

      <!-- Hero Image with overlays -->
      <div class="listing-hero position-relative">
        <img src="<%= listing.image.url %>" class="show-img" />

        <!-- Rating Badge — top left -->
        <div class="hero-rating-badge">
          <% if (totalReviews> 0) { %>
            ⭐ <%= avgRating %> · <%= totalReviews %> review<%= totalReviews> 1 ? "s" : "" %>
                  <% } else { %>
                    No reviews yet
                    <% } %>
        </div>

        <!-- Host Chip — bottom left -->
        <div class="hero-host-chip">
          <div class="host-avatar">
            <%= listing.owner ? listing.owner.username[0].toUpperCase() : "A" %>
          </div>
          <span>Hosted by <%= listing.owner ? listing.owner.username : "Admin" %></span>
        </div>
      </div>

      <!-- Owner Bar -->
      <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
        <div class="owner-bar">
          <span>🛡 You own this listing</span>
          <div class="d-flex gap-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn-edit">Edit</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
              <button class="btn-delete">Delete</button>
            </form>
          </div>
        </div>
        <% } %>

          <!-- Listing Info -->
          <div class="listing-body mt-2">
            <div class="d-flex justify-content-between align-items-start">
              <h3>
                <%= listing.title %>
              </h3>
              <div class="price-pill">₹<%= listing.price.toLocaleString("en-IN") %> / night</div>
            </div>

            <p class="listing-location">
              <i class="fa-solid fa-location-dot"></i>
              <%= listing.location %>, <%= listing.country %>
            </p>

            <p class="text-muted">
              <%= listing.description %>
            </p>

            <div class="amenity-tags">
              <span class="tag"><i class="fa-solid fa-wifi"></i> Wifi</span>
              <span class="tag"><i class="fa-solid fa-snowflake"></i> AC</span>
              <span class="tag"><i class="fa-solid fa-car"></i> Parking</span>
              <span class="tag"><i class="fa-solid fa-utensils"></i> Kitchen</span>
            </div>

            <div class="action-row mt-3">
              <button class="btn-save"><i class="fa-regular fa-heart"></i> Save</button>
            </div>

            <!-- Booking Form -->
            <% if (currUser) { %>
              <% if (!currUser._id.equals(listing.owner._id)) { %>
                <div class="booking-form mt-3">
                  <h5>Book this stay</h5>
                  <form action="/listings/<%= listing._id %>/bookings" method="POST">
                    <div class="row g-2">
                      <div class="col-6">
                        <label style="font-size:13px;">Check-in</label>
                        <input type="date" name="checkIn" class="form-control" required />
                      </div>
                      <div class="col-6">
                        <label style="font-size:13px;">Check-out</label>
                        <input type="date" name="checkOut" class="form-control" required />
                      </div>
                    </div>
                    <button class="btn-book w-100 mt-3">Confirm Booking</button>
                  </form>
                </div>
                <% } else { %>
                  <p class="text-muted mt-2" style="font-size:13px;">
                    🏠 Yeh aapki khud ki listing hai — aap book nahi kar sakte.
                  </p>
                  <% } %>
                    <% } else { %>
                      <a href="/login" class="btn-book d-block text-center mt-3 text-decoration-none">
                        Login karo to Book
                      </a>
                      <% } %>
          </div>
    </div>

    <!-- Reviews Section -->
    <div class="col-8 offset-2 mb-3">
      <hr />

      <!-- Rating Summary — real data -->
      <% if (totalReviews> 0) { %>
        <div class="review-summary mb-3">
          <div class="d-flex align-items-baseline gap-2">
            <span style="font-size:2rem; font-weight:600;">
              <%= avgRating %>
            </span>
            <span style="color:#888;">/ 5</span>
            <span style="font-size:13px; color:#888; margin-left:auto;">
              <%= totalReviews %> reviews
            </span>
          </div>
          <div class="review-bars mt-2">
            <% for (let star=5; star>= 1; star--) {
              let count = listing.reviews.filter(r => r.rating === star).length;
              let percent = totalReviews > 0 ? (count / totalReviews * 100).toFixed(0) : 0;
              %>
              <div class="d-flex align-items-center gap-2 mb-1">
                <span style="font-size:12px; width:30px;">
                  <%= star %> ★
                </span>
                <div style="flex:1; height:5px; background:#eee; border-radius:3px;">
                  <div style="width:<%= percent %>%; height:100%; background:#fe424d; border-radius:3px;"></div>
                </div>
                <span style="font-size:12px; width:20px; color:#888;">
                  <%= count %>
                </span>
              </div>
              <% } %>
          </div>
        </div>
        <hr />
        <% } %>

          <% if(currUser) { %>
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST">
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
              <div class="mb-3 mt-2">
                <textarea name="review[comment]" class="form-control" placeholder="Write your review..."
                  required></textarea>
              </div>
              <button class="btn btn-outline-dark mt-2">Submit</button>
            </form>
            <hr />
            <% } %>

              <% if(listing.reviews.length> 0) { %>
                <div class="row">
                  <% for (let review of listing.reviews) { %>
                    <div class="card col-5 ms-3 mb-3">
                      <div class="card-body">
                        <h5>
                          <%= review.author ? review.author.username : "Anonymous" %>
                        </h5>
                        <p class="starability-result" data-rating="<%= review.rating %>"></p>
                        <p>
                          <%= review.comment %>
                        </p>
                      </div>
                    </div>
                    <% } %>
                </div>
                <% } %>
    </div>

    <!-- Map Section -->
    <!-- Map Section -->
    <div class="col-8 offset-2 mb-3">
      <h3>Where you'll be</h3>
      <div id="map" style="height: 350px; width: 100%; border-radius: 10px;"></div>
    </div>

  </div>

  <!-- Script yahan rakho — map.js se pehle -->
  <script>
    const mapToken = "<%= process.env.MAPBOX_TOKEN %>";
    const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
  </script>

  <script src="/js/map.js"></script>