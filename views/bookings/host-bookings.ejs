<% layout("/layouts/boilerplate") %>

    <div class="container mt-4">
        <h3>My Listing Bookings</h3>
        <hr />

        <% if (bookings.length===0) { %>
            <div class="text-center mt-5">
                <i class="fa-solid fa-calendar-xmark" style="font-size:3rem; color:#ccc;"></i>
                <p class="mt-3 text-muted">Abhi tak koi booking nahi aayi.</p>
            </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead style="background:#f8f8f8;">
                            <tr>
                                <th>Listing</th>
                                <th>Guest</th>
                                <th>Check-in</th>
                                <th>Check-out</th>
                                <th>Nights</th>
                                <th>Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for (let booking of bookings) { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="<%= booking.listing.image.url %>"
                                                style="width:50px; height:40px; object-fit:cover; border-radius:6px;" />
                                            <span style="font-size:13px; font-weight:600;">
                                                <%= booking.listing.title %>
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <i class="fa-solid fa-user" style="color:#fe424d;"></i>
                                        <%= booking.user ? booking.user.username : "Unknown" %>
                                    </td>
                                    <td style="font-size:13px;">
                                        <%= booking.checkIn.toDateString() %>
                                    </td>
                                    <td style="font-size:13px;">
                                        <%= booking.checkOut.toDateString() %>
                                    </td>
                                    <td>
                                        <%= booking.totalNights %>
                                    </td>
                                    <td style="color:#fe424d; font-weight:600;">
                                        ₹<%= booking.totalPrice.toLocaleString("en-IN") %>
                                    </td>
                                    <td>
                                        <span class="badge"
                                            style="background:<%= booking.status === 'confirmed' ? '#d1fae5' : '#fee2e2' %>; color:<%= booking.status === 'confirmed' ? '#065f46' : '#991b1b' %>;">
                                            <%= booking.status.toUpperCase() %>
                                        </span>
                                    </td>
                                </tr>
                                <% } %>
                        </tbody>
                    </table>
                </div>
                <% } %>
    </div>